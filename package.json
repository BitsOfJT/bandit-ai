{
  "name": "local-llm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "bandit": "./bin/bandit"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "cli": "./bin/bandit",
    "build:cli": "go build -C cli-go -o ../bin/bandit .",
    "build:cli:windows": "GOOS=windows GOARCH=amd64 go build -C cli-go -o ../bin/bandit.exe .",
    "build:cli:linux": "GOOS=linux GOARCH=amd64 go build -C cli-go -o ../bin/bandit-linux .",
    "build:cli:all": "npm run build:cli && npm run build:cli:windows && npm run build:cli:linux",
    "build:wasm": "GOOS=js GOARCH=wasm go build -C cli-go/wasm -o ../../public/markdown.wasm ."
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
